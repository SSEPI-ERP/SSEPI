{
  "name": "ssepi-next-dataviewer",
  "version": "1.0.0",
  "description": "SSEPI-NEXT Data Viewer - Escritorio para ver datos del ERP",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "SSEPI",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "build": {
    "appId": "com.ssepi.next",
    "productName": "SSEPI-NEXT",
    "directories": {
