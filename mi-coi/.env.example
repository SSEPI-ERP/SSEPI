# Copia a .env en la raíz de mi-coi (no subir .env al repositorio).
# Necesario para que el bridge registre eventos en Supabase (coi_sync_log).

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: puerto y seguridad del bridge HTTP
# SSEPI_COI_BRIDGE_PORT=8765
# SSEPI_COI_BRIDGE_KEY=una-clave-secreta
